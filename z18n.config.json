{
    "baseLocale": "en",
    "languages": [
        "en",
        "ar",
        "fr"
    ],
    "translationsDir": "./translations",
    "srcDirs": [
        "./src"
    ],
    "includePatterns": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.html",
        "**/*.jsx",
        "**/*.vue"
    ],
    "excludePatterns": [
        "**/node_modules/**",
        "**/dist/**",
        "**/*.test.*"
    ],
    "llm": {
        "provider": "openai",
        "model": "gpt-4o-mini",
        "batchSize": 20,
        "reviewRequired": true
    }
}